olist_project:
  outputs:
    dev:
      type: postgres
      host: "{{ env_var('DB_HOST', 'localhost') }}"
      user: "{{ env_var('DB_USER') }}"
      password: "{{ env_var('DB_PASSWORD') }}"
      port: "{{ env_var('DB_PORT', '5433') | as_number }}"
      dbname: "{{ env_var('DB_NAME', 'olist') }}"
      schema: public
      threads: 4
  target: dev